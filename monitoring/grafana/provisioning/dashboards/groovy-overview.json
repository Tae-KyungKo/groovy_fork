{
  "uid": "groovy-overview",
  "title": "Groovy 로컬 관측",
  "tags": ["groovy", "local"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Targets Up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "up", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "[Backend] HTTP 요청률 (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (uri)", "legendFormat": "{{uri}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "[Backend] HTTP p95 레이턴시",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, uri))", "legendFormat": "{{uri}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "[Backend] JVM 힙 메모리 사용량",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "refId": "A", "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "{{id}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "[Backend] HikariCP 커넥션 풀",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "refId": "A", "expr": "hikaricp_connections_active", "legendFormat": "active" },
        { "refId": "B", "expr": "hikaricp_connections_idle", "legendFormat": "idle" },
        { "refId": "C", "expr": "hikaricp_connections_pending", "legendFormat": "pending" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "[MySQL] 연결 수",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "refId": "A", "expr": "mysql_global_status_threads_connected", "legendFormat": "connected" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "[MySQL] QPS",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "refId": "A", "expr": "rate(mysql_global_status_queries[1m])", "legendFormat": "queries/s" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "[Nginx] 활성 커넥션",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        { "refId": "A", "expr": "nginx_connections_active", "legendFormat": "active" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "[Nginx] 요청률 (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        { "refId": "A", "expr": "rate(nginx_http_requests_total[1m])", "legendFormat": "requests/s" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "[Node] CPU 사용률",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } },
      "targets": [
        { "refId": "A", "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "[Node] 메모리 사용률",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } },
      "targets": [
        { "refId": "A", "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "{{instance}}" }
      ]
    }
  ]
}
