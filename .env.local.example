# 루트 통합 docker-compose.local.yml (frontend + backend + mysql) 실행용 환경변수
# 로컬 실행 방법: 이 파일을 .env.local로 복사 후 필요 시 값 수정
#   cp .env.local.example .env.local
#   docker compose -f docker-compose.local.yml --env-file .env.local up -d --build
#
# 주의: 파일명이 기본값(.env)이 아니므로 docker compose가 자동으로 읽지 않는다.
#       반드시 --env-file .env.local 옵션을 함께 지정할 것.

# --- MySQL 컨테이너 ---
MYSQL_DATABASE=groovy_db
MYSQL_ROOT_PASSWORD=rootpassword
DB_PORT=3306

# --- JWT ---
# HS256 서명에 사용할 비밀키. 최소 256bit(32byte) 이상 권장. 아래 명령으로 직접 생성해서 사용할 것.
#   openssl rand -base64 64
JWT_SECRET_KEY=change-me-to-a-random-base64-secret-of-at-least-32-bytes

# --- 백엔드 컨테이너 ---
# 호스트에 노출할 포트. 여러 인스턴스를 띄우거나 포트가 겹칠 때만 변경.
SERVER_PORT=8080

# --- Prometheus 컨테이너 ---
# 호스트에 노출할 포트 (Prometheus 웹 UI / http://localhost:9090)
PROMETHEUS_PORT=9090

# --- mysqld_exporter 컨테이너 ---
# 호스트에서 직접 지표를 확인할 때 쓰는 포트 (http://localhost:9104/metrics). Prometheus는 내부 DNS로 접근하므로 필수는 아님.
MYSQLD_EXPORTER_PORT=9104

# --- nginx-exporter 컨테이너 ---
# 호스트에서 직접 지표를 확인할 때 쓰는 포트 (http://localhost:9113/metrics)
NGINX_EXPORTER_PORT=9113

# --- node-exporter 컨테이너 ---
# 호스트에서 직접 지표를 확인할 때 쓰는 포트 (http://localhost:9100/metrics)
# macOS + Docker Desktop 환경에서는 실제 macOS가 아니라 Docker Desktop이 띄우는 리눅스 VM의 자원을 보여준다.
NODE_EXPORTER_PORT=9100

# --- Grafana 컨테이너 ---
# 웹 UI 포트 (http://localhost:3000). 최초 로그인 계정은 admin / 아래 비밀번호.
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# --- HikariCP ---
# 로컬 개발 사양 기준 기본값. 운영 배포 시 DB 스펙/트래픽에 맞춰 조정할 것.
DB_POOL_MAX_SIZE=30
DB_POOL_MIN_IDLE=10

# --- CORS ---
# 프론트엔드 컨테이너 출처. 배포 도메인이 늘어나면 콤마로 구분해 나열할 것.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- 프론트엔드 컨테이너 ---
# 브라우저에서 호출할 백엔드 주소. 호스트에 노출된 SERVER_PORT를 가리켜야 한다.
VITE_API_BASE_URL=http://localhost:8080
# true면 실제 백엔드 대신 목업 응답 사용. 백엔드까지 함께 띄우는 통합 환경이므로 기본은 false.
VITE_USE_MOCK=false
