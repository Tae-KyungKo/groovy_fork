# 로컬 실행 방법: 이 파일을 .env로 복사 후 필요 시 값 수정
#   cp .env.example .env
#
# 추후 로컬(.env.local) / 운영(.env.prod) 환경으로 세분화 예정. 현재는 .env 단일 파일로 관리한다.

# --- docker-compose.local.yml (MySQL 컨테이너) ---
MYSQL_DATABASE=groovy_db
MYSQL_ROOT_PASSWORD=rootpassword
DB_PORT=3306

# --- Spring Boot 애플리케이션 (application.yml의 SPRING_DEV_DB_* 참조 값) ---
SPRING_DEV_DB_URL=jdbc:mysql://localhost:3306/groovy_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DEV_DB_USERNAME=root
SPRING_DEV_DB_PASSWORD=rootpassword
